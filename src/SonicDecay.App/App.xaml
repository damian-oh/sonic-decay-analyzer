<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:SonicDecay.App"
             xmlns:converters="clr-namespace:SonicDecay.App.Converters"
             x:Class="SonicDecay.App.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Value Converters -->
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
            <converters:StringNotEmptyConverter x:Key="StringNotEmptyConverter"/>
            <converters:IntToBoolConverter x:Key="IntToBoolConverter"/>
            <converters:StringNumberIndexConverter x:Key="StringNumberIndexConverter"/>
            <converters:CaptureButtonTextConverter x:Key="CaptureButtonTextConverter"/>
            <converters:DecayToColorConverter x:Key="DecayToColorConverter"/>
            <converters:SaveButtonTextConverter x:Key="SaveButtonTextConverter"/>
            <converters:NotNullConverter x:Key="NotNullConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
