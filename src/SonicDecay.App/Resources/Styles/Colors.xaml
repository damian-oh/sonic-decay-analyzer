<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <Color x:Key="Primary">#512BD4</Color>
    <Color x:Key="PrimaryDark">#ac99ea</Color>
    <Color x:Key="PrimaryDarkText">#242424</Color>
    <Color x:Key="Secondary">#DFD8F7</Color>
    <Color x:Key="SecondaryDarkText">#9880e5</Color>
    <Color x:Key="Tertiary">#2B0B98</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#190649</Color>
    <Color x:Key="OffBlack">#1f1f1f</Color>

    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray700">#333333</Color>
    <Color x:Key="Gray800">#282828</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>

    <!-- Health Indicator Colors (for decay percentage visualization) -->
    <Color x:Key="HealthExcellent">#22c55e</Color>  <!-- Green: 0-15% decay -->
    <Color x:Key="HealthGood">#eab308</Color>       <!-- Yellow: 15-30% decay -->
    <Color x:Key="HealthFair">#f97316</Color>       <!-- Orange: 30-50% decay -->
    <Color x:Key="HealthReplace">#ef4444</Color>    <!-- Red: 50%+ decay -->

    <SolidColorBrush x:Key="HealthExcellentBrush" Color="{StaticResource HealthExcellent}"/>
    <SolidColorBrush x:Key="HealthGoodBrush" Color="{StaticResource HealthGood}"/>
    <SolidColorBrush x:Key="HealthFairBrush" Color="{StaticResource HealthFair}"/>
    <SolidColorBrush x:Key="HealthReplaceBrush" Color="{StaticResource HealthReplace}"/>

    <!-- Analysis UI Colors -->
    <Color x:Key="AnalysisBackground">#1a1a2e</Color>
    <Color x:Key="AnalysisAccent">#4361ee</Color>
    <Color x:Key="MeterBackground">#2d2d44</Color>

    <SolidColorBrush x:Key="AnalysisBackgroundBrush" Color="{StaticResource AnalysisBackground}"/>
    <SolidColorBrush x:Key="AnalysisAccentBrush" Color="{StaticResource AnalysisAccent}"/>
    <SolidColorBrush x:Key="MeterBackgroundBrush" Color="{StaticResource MeterBackground}"/>

    <!-- Chart Series Colors -->
    <Color x:Key="ChartDecay">#FF4500</Color>
    <Color x:Key="ChartCentroid">#1E90FF</Color>
    <Color x:Key="ChartHfRatio">#9370DB</Color>

    <!-- Recommendation Urgency Colors -->
    <Color x:Key="UrgencyNone">#22c55e</Color>
    <Color x:Key="UrgencyMonitor">#3b82f6</Color>
    <Color x:Key="UrgencySoon">#eab308</Color>
    <Color x:Key="UrgencyRecommended">#f97316</Color>
    <Color x:Key="UrgencyUrgent">#ef4444</Color>

    <!-- Baseline Status Colors -->
    <Color x:Key="BaselineEstablished">#22c55e</Color>
    <Color x:Key="BaselineNotSet">#9ca3af</Color>
</ResourceDictionary>