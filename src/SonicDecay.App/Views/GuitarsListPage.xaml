<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SonicDecay.App.ViewModels"
             xmlns:models="clr-namespace:SonicDecay.App.Models"
             x:Class="SonicDecay.App.Views.GuitarsListPage"
             x:DataType="vm:GuitarsListViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,*,Auto" Padding="16">

        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <Label Text="Your guitars"
                   FontSize="14"
                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                   VerticalOptions="Center"/>
            <Button Grid.Column="1"
                    Text="Add"
                    Command="{Binding AddGuitarCommand}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    Padding="16,10"
                    SemanticProperties.Description="Add guitar"
                    SemanticProperties.Hint="Navigate to add a new guitar"/>
        </Grid>

        <ScrollView Grid.Row="1" Margin="0,16,0,0">
            <VerticalStackLayout Spacing="16">

                <Frame BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray800}}"
                       Padding="24"
                       CornerRadius="12"
                       BorderColor="Transparent"
                       IsVisible="{Binding HasNoGuitars}">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="12">
                        <Label Text="No Guitars"
                               FontSize="18"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"/>
                        <Label Text="Add a guitar to track string installations and decay history."
                               FontSize="14"
                               TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                        <Button Text="Add Guitar"
                                Command="{Binding AddGuitarCommand}"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                HorizontalOptions="Center"
                                SemanticProperties.Description="Add guitar"
                                SemanticProperties.Hint="Navigate to add a new guitar"/>
                    </VerticalStackLayout>
                </Frame>

                <CollectionView ItemsSource="{Binding Guitars}"
                                SelectionMode="Single"
                                IsVisible="{Binding HasNoGuitars, Converter={StaticResource InvertedBoolConverter}}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Guitar">
                            <Frame BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                                   Padding="16"
                                   Margin="0,0,0,8"
                                   CornerRadius="12"
                                   BorderColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}">
                                <Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="8">
                                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                                        <Label Text="{Binding Name}"
                                               FontSize="16"
                                               FontAttributes="Bold"/>
                                        <Label Text="{Binding Make, TargetNullValue='—'}"
                                               FontSize="14"
                                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"/>
                                    </VerticalStackLayout>
                                    <Button Grid.Column="1" Grid.RowSpan="2"
                                            Text="Delete"
                                            FontSize="11"
                                            Padding="8,4"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteGuitarCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="{StaticResource HealthReplace}"
                                            TextColor="White"
                                            VerticalOptions="Center"
                                            SemanticProperties.Description="Delete guitar"
                                            SemanticProperties.Hint="Delete this guitar and all associated data"/>
                                    <Label Grid.Column="2" Grid.RowSpan="2"
                                           Text="›"
                                           FontSize="24"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
                                           VerticalOptions="Center"/>
                                </Grid>
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectGuitarCommand}"
                                                         CommandParameter="{Binding .}"/>
                                </Frame.GestureRecognizers>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <Button Grid.Row="2"
                Text="Back"
                Command="{Binding GoBackCommand}"
                Margin="0,16,0,0"
                BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                SemanticProperties.Description="Go back"
                SemanticProperties.Hint="Navigate to the previous page"/>

        <Frame Grid.RowSpan="3"
               BackgroundColor="{AppThemeBinding Light=#80FFFFFF, Dark=#80000000}"
               IsVisible="{Binding IsBusy}"
               BorderColor="Transparent">
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               Color="{StaticResource Primary}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
        </Frame>

    </Grid>

</ContentPage>
