<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SonicDecay.App.ViewModels"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Maui;assembly=LiveChartsCore.SkiaSharpView.Maui"
             x:Class="SonicDecay.App.Views.DecayChartPage"
             x:DataType="vm:DecayChartViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Padding="16">

        <!-- Chart Context Header -->
        <Label Grid.Row="0"
               Text="{Binding ChartSubtitle}"
               FontSize="14"
               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
               HorizontalOptions="Center"
               Margin="0,0,0,8"
               IsVisible="{Binding ChartSubtitle, Converter={StaticResource StringNotEmptyConverter}}"/>

        <!-- String Selector Bar -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*,*,*" ColumnSpacing="6" Margin="0,0,0,8"
              IsVisible="{Binding HasStringSelector}">
            <!-- String 1 (E1) -->
            <Frame Grid.Column="0" Padding="6,8" CornerRadius="8"
                   BorderColor="{Binding StringSelectorItems[0].StatusColor}"
                   BackgroundColor="{Binding StringSelectorItems[0].IsSelected, Converter={StaticResource BoolToColorConverter}}">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectStringCommand}" CommandParameter="1"/>
                </Frame.GestureRecognizers>
                <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                    <Label Text="{Binding StringSelectorItems[0].StatusIcon}" FontSize="14"
                           TextColor="{Binding StringSelectorItems[0].IsSelected, Converter={StaticResource BoolToTextColorConverter}}"
                           HorizontalOptions="Center"/>
                    <Label Text="{Binding StringSelectorItems[0].NoteName}" FontSize="11" FontAttributes="Bold"
                           TextColor="{Binding StringSelectorItems[0].IsSelected, Converter={StaticResource BoolToTextColorConverter}}"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>
            <!-- String 2 (B2) -->
            <Frame Grid.Column="1" Padding="6,8" CornerRadius="8"
                   BorderColor="{Binding StringSelectorItems[1].StatusColor}"
                   BackgroundColor="{Binding StringSelectorItems[1].IsSelected, Converter={StaticResource BoolToColorConverter}}">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectStringCommand}" CommandParameter="2"/>
                </Frame.GestureRecognizers>
                <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                    <Label Text="{Binding StringSelectorItems[1].StatusIcon}" FontSize="14"
                           TextColor="{Binding StringSelectorItems[1].IsSelected, Converter={StaticResource BoolToTextColorConverter}}"
                           HorizontalOptions="Center"/>
                    <Label Text="{Binding StringSelectorItems[1].NoteName}" FontSize="11" FontAttributes="Bold"
                           TextColor="{Binding StringSelectorItems[1].IsSelected, Converter={StaticResource BoolToTextColorConverter}}"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>
            <!-- String 3 (G3) -->
            <Frame Grid.Column="2" Padding="6,8" CornerRadius="8"
                   BorderColor="{Binding StringSelectorItems[2].StatusColor}"
                   BackgroundColor="{Binding StringSelectorItems[2].IsSelected, Converter={StaticResource BoolToColorConverter}}">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectStringCommand}" CommandParameter="3"/>
                </Frame.GestureRecognizers>
                <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                    <Label Text="{Binding StringSelectorItems[2].StatusIcon}" FontSize="14"
                           TextColor="{Binding StringSelectorItems[2].IsSelected, Converter={StaticResource BoolToTextColorConverter}}"
                           HorizontalOptions="Center"/>
                    <Label Text="{Binding StringSelectorItems[2].NoteName}" FontSize="11" FontAttributes="Bold"
                           TextColor="{Binding StringSelectorItems[2].IsSelected, Converter={StaticResource BoolToTextColorConverter}}"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>
            <!-- String 4 (D4) -->
            <Frame Grid.Column="3" Padding="6,8" CornerRadius="8"
                   BorderColor="{Binding StringSelectorItems[3].StatusColor}"
                   BackgroundColor="{Binding StringSelectorItems[3].IsSelected, Converter={StaticResource BoolToColorConverter}}">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectStringCommand}" CommandParameter="4"/>
                </Frame.GestureRecognizers>
                <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                    <Label Text="{Binding StringSelectorItems[3].StatusIcon}" FontSize="14"
                           TextColor="{Binding StringSelectorItems[3].IsSelected, Converter={StaticResource BoolToTextColorConverter}}"
                           HorizontalOptions="Center"/>
                    <Label Text="{Binding StringSelectorItems[3].NoteName}" FontSize="11" FontAttributes="Bold"
                           TextColor="{Binding StringSelectorItems[3].IsSelected, Converter={StaticResource BoolToTextColorConverter}}"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>
            <!-- String 5 (A5) -->
            <Frame Grid.Column="4" Padding="6,8" CornerRadius="8"
                   BorderColor="{Binding StringSelectorItems[4].StatusColor}"
                   BackgroundColor="{Binding StringSelectorItems[4].IsSelected, Converter={StaticResource BoolToColorConverter}}">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectStringCommand}" CommandParameter="5"/>
                </Frame.GestureRecognizers>
                <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                    <Label Text="{Binding StringSelectorItems[4].StatusIcon}" FontSize="14"
                           TextColor="{Binding StringSelectorItems[4].IsSelected, Converter={StaticResource BoolToTextColorConverter}}"
                           HorizontalOptions="Center"/>
                    <Label Text="{Binding StringSelectorItems[4].NoteName}" FontSize="11" FontAttributes="Bold"
                           TextColor="{Binding StringSelectorItems[4].IsSelected, Converter={StaticResource BoolToTextColorConverter}}"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>
            <!-- String 6 (E6) -->
            <Frame Grid.Column="5" Padding="6,8" CornerRadius="8"
                   BorderColor="{Binding StringSelectorItems[5].StatusColor}"
                   BackgroundColor="{Binding StringSelectorItems[5].IsSelected, Converter={StaticResource BoolToColorConverter}}">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectStringCommand}" CommandParameter="6"/>
                </Frame.GestureRecognizers>
                <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                    <Label Text="{Binding StringSelectorItems[5].StatusIcon}" FontSize="14"
                           TextColor="{Binding StringSelectorItems[5].IsSelected, Converter={StaticResource BoolToTextColorConverter}}"
                           HorizontalOptions="Center"/>
                    <Label Text="{Binding StringSelectorItems[5].NoteName}" FontSize="11" FontAttributes="Bold"
                           TextColor="{Binding StringSelectorItems[5].IsSelected, Converter={StaticResource BoolToTextColorConverter}}"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>
        </Grid>

        <!-- Chart -->
        <lvc:CartesianChart Grid.Row="2"
                            Series="{Binding Series}"
                            XAxes="{Binding XAxes}"
                            YAxes="{Binding YAxes}"
                            ZoomMode="X"
                            TooltipPosition="Top"
                            IsVisible="{Binding HasData}"
                            SemanticProperties.Description="Decay trend chart"
                            SemanticProperties.Hint="Shows spectral decay measurements over time">
        </lvc:CartesianChart>

        <!-- No Data Message -->
        <Frame Grid.Row="2"
               BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray800}}"
               Padding="32"
               CornerRadius="16"
               BorderColor="Transparent"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               IsVisible="{Binding HasNoData}">
            <VerticalStackLayout HorizontalOptions="Center" Spacing="16">
                <Label Text="No Decay Data"
                       FontSize="24"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>
                <Label Text="There are no measurements recorded for this string baseline yet."
                       FontSize="14"
                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"/>
                <Label Text="Start capturing audio on the main page and play your string to record decay measurements."
                       FontSize="12"
                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       MaximumWidthRequest="300"/>
            </VerticalStackLayout>
        </Frame>

        <!-- Metric Toggle Buttons -->
        <Frame Grid.Row="3"
               BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
               Padding="12"
               CornerRadius="12"
               BorderColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
               Margin="0,16,0,0"
               IsVisible="{Binding HasData}">
            <VerticalStackLayout Spacing="12">
                <Label Text="Visible Metrics"
                       FontSize="14"
                       FontAttributes="Bold"/>

                <FlexLayout Wrap="Wrap" JustifyContent="Start" AlignItems="Start">
                    <Button Text="Decay %"
                            Margin="4"
                            Padding="12,8"
                            FontSize="12"
                            Command="{Binding ToggleDecayCommand}"
                            BackgroundColor="{Binding ShowDecayPercentage, Converter={StaticResource BoolToColorConverter}}"
                            TextColor="{Binding ShowDecayPercentage, Converter={StaticResource BoolToTextColorConverter}}"
                            SemanticProperties.Description="Toggle decay percentage series"
                            SemanticProperties.Hint="Show or hide the decay percentage line on the chart"/>

                    <Button Text="Centroid"
                            Margin="4"
                            Padding="12,8"
                            FontSize="12"
                            Command="{Binding ToggleCentroidCommand}"
                            BackgroundColor="{Binding ShowSpectralCentroid, Converter={StaticResource BoolToColorConverter}}"
                            TextColor="{Binding ShowSpectralCentroid, Converter={StaticResource BoolToTextColorConverter}}"
                            SemanticProperties.Description="Toggle spectral centroid series"
                            SemanticProperties.Hint="Show or hide the spectral centroid line on the chart"/>

                    <Button Text="HF Ratio"
                            Margin="4"
                            Padding="12,8"
                            FontSize="12"
                            Command="{Binding ToggleHfRatioCommand}"
                            BackgroundColor="{Binding ShowHfRatio, Converter={StaticResource BoolToColorConverter}}"
                            TextColor="{Binding ShowHfRatio, Converter={StaticResource BoolToTextColorConverter}}"
                            SemanticProperties.Description="Toggle high-frequency ratio series"
                            SemanticProperties.Hint="Show or hide the HF energy ratio line on the chart"/>
                </FlexLayout>

                <!-- Legend -->
                <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*" ColumnSpacing="8">
                    <BoxView Grid.Column="0"
                             Color="{StaticResource ChartDecay}"
                             WidthRequest="16"
                             HeightRequest="3"
                             VerticalOptions="Center"/>
                    <Label Grid.Column="1"
                           Text="Decay %"
                           FontSize="10"
                           VerticalOptions="Center"/>

                    <BoxView Grid.Column="2"
                             Color="{StaticResource ChartCentroid}"
                             WidthRequest="16"
                             HeightRequest="3"
                             VerticalOptions="Center"/>
                    <Label Grid.Column="3"
                           Text="Centroid (Hz/10)"
                           FontSize="10"
                           VerticalOptions="Center"/>

                    <BoxView Grid.Column="4"
                             Color="{StaticResource ChartHfRatio}"
                             WidthRequest="16"
                             HeightRequest="3"
                             VerticalOptions="Center"/>
                    <Label Grid.Column="5"
                           Text="HF Ratio (x100)"
                           FontSize="10"
                           VerticalOptions="Center"/>
                </Grid>
            </VerticalStackLayout>
        </Frame>

        <!-- Action Buttons -->
        <Grid Grid.Row="4" ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,16,0,0">
            <Button Text="Back"
                    Command="{Binding GoBackCommand}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                    TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                    SemanticProperties.Description="Go back"
                    SemanticProperties.Hint="Navigate to the previous page"/>

            <Button Grid.Column="1"
                    Text="Refresh"
                    Command="{Binding RefreshCommand}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    SemanticProperties.Description="Refresh chart data"
                    SemanticProperties.Hint="Reload measurement data and redraw the chart"/>
        </Grid>

        <!-- Loading Overlay -->
        <Frame Grid.RowSpan="5"
               BackgroundColor="{AppThemeBinding Light=#80FFFFFF, Dark=#80000000}"
               IsVisible="{Binding IsBusy}"
               BorderColor="Transparent">
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               Color="{StaticResource Primary}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
        </Frame>
    </Grid>

</ContentPage>
