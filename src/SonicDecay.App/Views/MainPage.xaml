<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SonicDecay.App.ViewModels"
             xmlns:models="clr-namespace:SonicDecay.App.Models"
             x:Class="SonicDecay.App.Views.MainPage"
             x:DataType="vm:MainViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,*,Auto" Padding="16">

        <!-- Header Section: Collapsible Context -->
        <VerticalStackLayout Grid.Row="0" Spacing="8">
            <Frame BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}"
                   Padding="12"
                   CornerRadius="8"
                   BorderColor="Transparent">
                <VerticalStackLayout Spacing="0">
                    <!-- Tappable header: tap toggles expand/collapse -->
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8"
                          x:Name="ContextHeader">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleContextExpandedCommand}"/>
                        </Grid.GestureRecognizers>
                        <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                            <Label Text="Selection"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"/>
                            <Label Text="{Binding ContextSummaryText}"
                                   FontSize="14"
                                   LineBreakMode="TailTruncation"
                                   MaximumWidthRequest="400"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="1"
                               Text="{Binding IsContextExpanded, Converter={StaticResource ExpandChevronConverter}}"
                               FontSize="16"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                               VerticalOptions="Center"/>
                    </Grid>
                    <!-- Content: visible when expanded -->
                    <VerticalStackLayout Spacing="8" Margin="0,12,0,0"
                                         IsVisible="{Binding IsContextExpanded}">

                        <!-- Guitar Selection -->
                        <Frame BackgroundColor="Transparent"
                               Padding="0"
                               CornerRadius="8"
                               BorderColor="Transparent">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <Picker Grid.Column="0"
                                        Title="Select Guitar"
                                        ItemsSource="{Binding Guitars}"
                                        SelectedItem="{Binding SelectedGuitar}"
                                        ItemDisplayBinding="{Binding Name}"
                                        IsEnabled="{Binding IsCapturing, Converter={StaticResource InvertedBoolConverter}}"
                                        SemanticProperties.Description="Guitar selection"
                                        SemanticProperties.Hint="Select the guitar to analyze"/>

                                <Button Grid.Column="1"
                                        Text="+"
                                        WidthRequest="44"
                                        HeightRequest="44"
                                        Command="{Binding NavigateToGuitarInputCommand}"
                                        SemanticProperties.Hint="Add guitar"/>
                            </Grid>
                        </Frame>

                        <!-- String Set Pairing Selection -->
                        <Frame BackgroundColor="Transparent"
                               Padding="0"
                               CornerRadius="8"
                               BorderColor="Transparent"
                               IsVisible="{Binding HasPairings}">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <Picker Grid.Column="0"
                                        Title="Select String Set Installation"
                                        ItemsSource="{Binding AvailablePairings}"
                                        SelectedItem="{Binding SelectedPairing}"
                                        ItemDisplayBinding="{Binding DisplayName}"
                                        IsEnabled="{Binding IsCapturing, Converter={StaticResource InvertedBoolConverter}}"/>

                                <Button Grid.Column="1"
                                        Text="×"
                                        FontSize="24"
                                        WidthRequest="44"
                                        HeightRequest="44"
                                        Command="{Binding DeletePairingCommand}"
                                        BackgroundColor="{StaticResource HealthReplace}"
                                        TextColor="White"
                                        IsEnabled="{Binding IsCapturing, Converter={StaticResource InvertedBoolConverter}}"
                                        SemanticProperties.Hint="Delete selected string set pairing"/>
                            </Grid>
                        </Frame>

                        <!-- String Set Selection -->
                        <Frame BackgroundColor="Transparent"
                               Padding="0"
                               CornerRadius="8"
                               BorderColor="Transparent">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="8">

                                <Picker Grid.Row="0" Grid.Column="0"
                                        Title="Select Brand"
                                        ItemsSource="{Binding AvailableBrands}"
                                        SelectedItem="{Binding SelectedBrand}"
                                        IsEnabled="{Binding IsCapturing, Converter={StaticResource InvertedBoolConverter}}"/>

                                <Button Grid.Row="0" Grid.Column="1"
                                        Text="+"
                                        WidthRequest="44"
                                        HeightRequest="44"
                                        Command="{Binding NavigateToStringInputCommand}"
                                        SemanticProperties.Hint="Add custom string set"/>

                                <Picker Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                        Title="Select Model"
                                        ItemsSource="{Binding FilteredModels}"
                                        SelectedItem="{Binding SelectedStringSet}"
                                        ItemDisplayBinding="{Binding Model}"
                                        IsEnabled="{Binding IsCapturing, Converter={StaticResource InvertedBoolConverter}}"/>

                                <Picker Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                        Title="Select String"
                                        ItemsSource="{Binding StringNumbers}"
                                        SelectedIndex="{Binding SelectedStringNumber, Converter={StaticResource StringNumberIndexConverter}}"
                                        IsEnabled="{Binding IsCapturing, Converter={StaticResource InvertedBoolConverter}}"/>
                            </Grid>
                        </Frame>

                        <!-- Baseline Status Indicators for All Strings -->
                        <Frame BackgroundColor="Transparent"
                               Padding="0"
                               CornerRadius="8"
                               BorderColor="Transparent"
                               IsVisible="{Binding SelectedStringSet, Converter={StaticResource IsNotNullConverter}}">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Baseline Status"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"/>
                                <Grid ColumnDefinitions="*,*,*,*,*,*" ColumnSpacing="4">
                                    <Frame Grid.Column="0" Padding="8,4" CornerRadius="6" BorderColor="{Binding StringNumbers[0].StatusColor}" BackgroundColor="Transparent" HorizontalOptions="Center">
                                        <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                                            <Label Text="{Binding StringNumbers[0].StatusIcon}" FontSize="14" TextColor="{Binding StringNumbers[0].StatusColor}" HorizontalOptions="Center"/>
                                            <Label Text="E1" FontSize="10" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" HorizontalOptions="Center"/>
                                        </VerticalStackLayout>
                                    </Frame>
                                    <Frame Grid.Column="1" Padding="8,4" CornerRadius="6" BorderColor="{Binding StringNumbers[1].StatusColor}" BackgroundColor="Transparent" HorizontalOptions="Center">
                                        <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                                            <Label Text="{Binding StringNumbers[1].StatusIcon}" FontSize="14" TextColor="{Binding StringNumbers[1].StatusColor}" HorizontalOptions="Center"/>
                                            <Label Text="B2" FontSize="10" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" HorizontalOptions="Center"/>
                                        </VerticalStackLayout>
                                    </Frame>
                                    <Frame Grid.Column="2" Padding="8,4" CornerRadius="6" BorderColor="{Binding StringNumbers[2].StatusColor}" BackgroundColor="Transparent" HorizontalOptions="Center">
                                        <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                                            <Label Text="{Binding StringNumbers[2].StatusIcon}" FontSize="14" TextColor="{Binding StringNumbers[2].StatusColor}" HorizontalOptions="Center"/>
                                            <Label Text="G3" FontSize="10" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" HorizontalOptions="Center"/>
                                        </VerticalStackLayout>
                                    </Frame>
                                    <Frame Grid.Column="3" Padding="8,4" CornerRadius="6" BorderColor="{Binding StringNumbers[3].StatusColor}" BackgroundColor="Transparent" HorizontalOptions="Center">
                                        <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                                            <Label Text="{Binding StringNumbers[3].StatusIcon}" FontSize="14" TextColor="{Binding StringNumbers[3].StatusColor}" HorizontalOptions="Center"/>
                                            <Label Text="D4" FontSize="10" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" HorizontalOptions="Center"/>
                                        </VerticalStackLayout>
                                    </Frame>
                                    <Frame Grid.Column="4" Padding="8,4" CornerRadius="6" BorderColor="{Binding StringNumbers[4].StatusColor}" BackgroundColor="Transparent" HorizontalOptions="Center">
                                        <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                                            <Label Text="{Binding StringNumbers[4].StatusIcon}" FontSize="14" TextColor="{Binding StringNumbers[4].StatusColor}" HorizontalOptions="Center"/>
                                            <Label Text="A5" FontSize="10" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" HorizontalOptions="Center"/>
                                        </VerticalStackLayout>
                                    </Frame>
                                    <Frame Grid.Column="5" Padding="8,4" CornerRadius="6" BorderColor="{Binding StringNumbers[5].StatusColor}" BackgroundColor="Transparent" HorizontalOptions="Center">
                                        <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                                            <Label Text="{Binding StringNumbers[5].StatusIcon}" FontSize="14" TextColor="{Binding StringNumbers[5].StatusColor}" HorizontalOptions="Center"/>
                                            <Label Text="E6" FontSize="10" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" HorizontalOptions="Center"/>
                                        </VerticalStackLayout>
                                    </Frame>
                                </Grid>
                            </VerticalStackLayout>
                        </Frame>

                        <Label Text="{Binding BaselineStatus}"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>

        <!-- Main Analysis Display -->
        <ScrollView Grid.Row="1" Margin="0,16,0,0">
            <VerticalStackLayout Spacing="16">

                <!-- Health Indicator Card -->
                <Frame BackgroundColor="{Binding HealthColor}"
                       Padding="24"
                       CornerRadius="16"
                       BorderColor="Transparent"
                       IsVisible="{Binding HasBaseline}">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="8">
                        <Label Text="{Binding DecayPercentage, StringFormat='{0:F1}%'}"
                               FontSize="48"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center"/>
                        <Label Text="{Binding HealthStatus}"
                               FontSize="18"
                               TextColor="White"
                               HorizontalOptions="Center"/>
                        <Label Text="Decay from baseline"
                               FontSize="12"
                               TextColor="White"
                               Opacity="0.8"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Spectral Metrics -->
                <Frame BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                       Padding="16"
                       CornerRadius="12"
                       BorderColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,*" RowSpacing="12" ColumnSpacing="16">

                        <!-- Spectral Centroid -->
                        <VerticalStackLayout Grid.Row="0" Grid.Column="0">
                            <Label Text="Spectral Centroid"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"/>
                            <Label Text="{Binding CurrentCentroid, StringFormat='{0:F0} Hz'}"
                                   FontSize="20"
                                   FontAttributes="Bold"/>
                        </VerticalStackLayout>

                        <!-- HF Energy Ratio -->
                        <VerticalStackLayout Grid.Row="0" Grid.Column="1">
                            <Label Text="HF Energy Ratio"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"/>
                            <Label Text="{Binding CurrentHfRatio, StringFormat='{0:F3}'}"
                                   FontSize="20"
                                   FontAttributes="Bold"/>
                        </VerticalStackLayout>

                        <!-- Fundamental Frequency -->
                        <VerticalStackLayout Grid.Row="1" Grid.Column="0">
                            <Label Text="Fundamental (f₀)"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"/>
                            <Label Text="{Binding FundamentalFreq, StringFormat='{0:F1} Hz'}"
                                   FontSize="20"
                                   FontAttributes="Bold"/>
                        </VerticalStackLayout>

                        <!-- RMS Level -->
                        <VerticalStackLayout Grid.Row="1" Grid.Column="1">
                            <Label Text="Input Level"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"/>
                            <ProgressBar Progress="{Binding RmsLevel}"
                                         ProgressColor="{StaticResource Primary}"
                                         HeightRequest="8"/>
                        </VerticalStackLayout>

                        <!-- Status Message -->
                        <Label Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                               Text="{Binding StatusMessage}"
                               FontSize="14"
                               TextColor="{StaticResource Primary}"
                               HorizontalOptions="Center"/>

                        <!-- Error Message -->
                        <Label Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                               Text="{Binding ErrorMessage}"
                               FontSize="12"
                               TextColor="{StaticResource HealthReplace}"
                               HorizontalOptions="Center"
                               IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}"/>
                    </Grid>
                </Frame>

                <!-- Replacement Recommendation -->
                <Frame BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                       Padding="16"
                       CornerRadius="12"
                       BorderColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                       IsVisible="{Binding HasRecommendation}">
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Replacement Recommendation"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center"/>
                            <Button Grid.Column="1"
                                    Text="↻"
                                    WidthRequest="36"
                                    HeightRequest="36"
                                    FontSize="16"
                                    Padding="0"
                                    Command="{Binding RefreshRecommendationCommand}"
                                    BackgroundColor="Transparent"
                                    TextColor="{StaticResource Primary}"
                                    SemanticProperties.Hint="Refresh recommendation"/>
                        </Grid>

                        <!-- Urgency Badge -->
                        <Frame BackgroundColor="{Binding RecommendationUrgencyColor}"
                               Padding="12,8"
                               CornerRadius="8"
                               BorderColor="Transparent"
                               HorizontalOptions="Start">
                            <Label Text="{Binding RecommendationUrgencyText}"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="White"/>
                        </Frame>

                        <!-- Recommendation Message -->
                        <Label Text="{Binding Recommendation.Message}"
                               FontSize="14"
                               LineBreakMode="WordWrap"/>

                        <!-- Prediction Details Grid -->
                        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,*,*" RowSpacing="8" ColumnSpacing="8">
                            <!-- Hours Remaining -->
                            <VerticalStackLayout Grid.Row="0" Grid.Column="0">
                                <Label Text="Play Hours Left"
                                       FontSize="10"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"/>
                                <Label Text="{Binding EstimatedHoursRemainingText}"
                                       FontSize="14"
                                       FontAttributes="Bold"/>
                            </VerticalStackLayout>

                            <!-- Projected Date -->
                            <VerticalStackLayout Grid.Row="0" Grid.Column="1">
                                <Label Text="Replace By"
                                       FontSize="10"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"/>
                                <Label Text="{Binding ProjectedReplacementDateText}"
                                       FontSize="14"
                                       FontAttributes="Bold"/>
                            </VerticalStackLayout>

                            <!-- Confidence -->
                            <VerticalStackLayout Grid.Row="0" Grid.Column="2">
                                <Label Text="Confidence"
                                       FontSize="10"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"/>
                                <Label Text="{Binding RecommendationConfidenceText}"
                                       FontSize="14"
                                       FontAttributes="Bold"/>
                            </VerticalStackLayout>

                            <!-- Health Score -->
                            <VerticalStackLayout Grid.Row="1" Grid.Column="0">
                                <Label Text="Health Score"
                                       FontSize="10"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"/>
                                <Label Text="{Binding Recommendation.HealthScore, StringFormat='{0:F0}/100'}"
                                       FontSize="14"
                                       FontAttributes="Bold"/>
                            </VerticalStackLayout>

                            <!-- Decay Rate -->
                            <VerticalStackLayout Grid.Row="1" Grid.Column="1">
                                <Label Text="Decay Rate"
                                       FontSize="10"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"/>
                                <Label Text="{Binding Recommendation.DecayRatePerHour, StringFormat='{0:F2}%/hr'}"
                                       FontSize="14"
                                       FontAttributes="Bold"/>
                            </VerticalStackLayout>

                            <!-- Measurements -->
                            <VerticalStackLayout Grid.Row="1" Grid.Column="2">
                                <Label Text="Measurements"
                                       FontSize="10"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"/>
                                <Label Text="{Binding Recommendation.MeasurementCount}"
                                       FontSize="14"
                                       FontAttributes="Bold"/>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Loading Indicator -->
                        <ActivityIndicator IsRunning="{Binding IsLoadingRecommendation}"
                                           IsVisible="{Binding IsLoadingRecommendation}"
                                           Color="{StaticResource Primary}"
                                           HeightRequest="20"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Decay History -->
                <Frame BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                       Padding="16"
                       CornerRadius="12"
                       BorderColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                       IsVisible="{Binding DecayHistory.Count, Converter={StaticResource IntToBoolConverter}}">
                    <VerticalStackLayout Spacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Recent Measurements"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center"/>
                            <Button Grid.Column="1"
                                    Text="View Chart"
                                    FontSize="12"
                                    Padding="12,6"
                                    Command="{Binding NavigateToChartCommand}"
                                    BackgroundColor="{StaticResource Primary}"
                                    TextColor="White"/>
                        </Grid>

                        <CollectionView ItemsSource="{Binding DecayHistory}"
                                        HeightRequest="200">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:MeasurementLog">
                                    <Grid ColumnDefinitions="*,Auto,Auto" Padding="0,8" ColumnSpacing="12">
                                        <Label Text="{Binding MeasuredAt, StringFormat='{0:MMM dd, HH:mm}'}"
                                               FontSize="12"
                                               VerticalOptions="Center"/>
                                        <Label Grid.Column="1"
                                               Text="{Binding CurrentCentroid, StringFormat='{0:F0} Hz'}"
                                               FontSize="12"
                                               VerticalOptions="Center"/>
                                        <Label Grid.Column="2"
                                               Text="{Binding DecayPercentage, StringFormat='{0:F1}%'}"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               VerticalOptions="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>

                <!-- No Decay History Message -->
                <Frame BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray800}}"
                       Padding="24"
                       CornerRadius="12"
                       BorderColor="Transparent"
                       IsVisible="{Binding HasBaseline}">
                    <Frame.Triggers>
                        <DataTrigger TargetType="Frame" Binding="{Binding DecayHistory.Count, Converter={StaticResource IntToBoolConverter}}" Value="True">
                            <Setter Property="IsVisible" Value="False"/>
                        </DataTrigger>
                    </Frame.Triggers>
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="8">
                        <Label Text="No Measurements Yet"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"/>
                        <Label Text="Start capturing audio and play your string to record decay measurements."
                               FontSize="12"
                               TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Library shortcut -->
                <Button Text="Library"
                        FontSize="14"
                        Padding="16,12"
                        Command="{Binding NavigateToLibraryCommand}"
                        BackgroundColor="{StaticResource AnalysisAccent}"
                        TextColor="White"
                        SemanticProperties.Hint="Open library to manage guitars, string sets, and pairings"/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Action Buttons -->
        <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,16,0,0">

            <!-- Permission Request (shown when no permission) -->
            <Button Grid.Column="0" Grid.ColumnSpan="2"
                    Text="Grant Microphone Permission"
                    Command="{Binding RequestPermissionCommand}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    IsVisible="{Binding HasPermission, Converter={StaticResource InvertedBoolConverter}}"
                    SemanticProperties.Description="Grant microphone permission"
                    SemanticProperties.Hint="Tap to request microphone access for audio capture"/>

            <!-- Capture Controls (shown when has permission) -->
            <Button Grid.Column="0"
                    Text="{Binding IsCapturing, Converter={StaticResource CaptureButtonTextConverter}}"
                    Command="{Binding StartCaptureCommand}"
                    BackgroundColor="{StaticResource HealthExcellent}"
                    TextColor="White"
                    IsVisible="{Binding HasPermission}"
                    SemanticProperties.Description="Start audio capture"
                    SemanticProperties.Hint="Begin recording audio from microphone for spectral analysis">
                <Button.Triggers>
                    <DataTrigger TargetType="Button" Binding="{Binding IsCapturing}" Value="True">
                        <Setter Property="IsVisible" Value="False"/>
                    </DataTrigger>
                </Button.Triggers>
            </Button>

            <Button Grid.Column="0"
                    Text="Stop Capture"
                    Command="{Binding StopCaptureCommand}"
                    BackgroundColor="{StaticResource HealthReplace}"
                    TextColor="White"
                    IsVisible="{Binding IsCapturing}"
                    SemanticProperties.Description="Stop audio capture"
                    SemanticProperties.Hint="Stop recording audio"/>

            <Button Grid.Column="1"
                    Text="Set Baseline"
                    Command="{Binding EstablishBaselineCommand}"
                    BackgroundColor="{StaticResource AnalysisAccent}"
                    TextColor="White"
                    IsVisible="{Binding HasPermission}"
                    IsEnabled="{Binding IsCapturing}"
                    SemanticProperties.Description="Set baseline measurement"
                    SemanticProperties.Hint="Record the fresh string reference measurement"/>
        </Grid>

        <!-- Loading Overlay -->
        <Frame Grid.RowSpan="3"
               BackgroundColor="{AppThemeBinding Light=#80FFFFFF, Dark=#80000000}"
               IsVisible="{Binding IsBusy}"
               BorderColor="Transparent">
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               Color="{StaticResource Primary}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
        </Frame>
    </Grid>

</ContentPage>
